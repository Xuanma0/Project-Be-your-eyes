{
  "profiles": [
    {
      "name": "baseline_reference",
      "services": {
        "seg": "reference",
        "depth": "reference",
        "ocr": "reference"
      },
      "env": {
        "BYES_ENABLE_SEG": "1",
        "BYES_ENABLE_DEPTH": "1",
        "BYES_ENABLE_OCR": "1"
