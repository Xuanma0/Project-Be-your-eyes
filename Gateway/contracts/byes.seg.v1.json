{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-be-your-eyes/contracts/byes.seg.v1.json",
  "title": "BYES Seg Payload v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "segments"
  ],
  "properties": {
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "label",
          "score",
          "bbox"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "number"
            }
          },
          "trackId": {
            "type": "string",
            "minLength": 1
          },
          "trackState": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "init",
              "track",
              "lost",
              null
            ]
          },
          "mask": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "format",
              "size",
              "counts"
            ],
            "properties": {
              "format": {
                "const": "rle_v1"
              },
              "size": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "counts": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "segmentsCount": {
      "type": "integer",
      "minimum": 0
    },
    "imageWidth": {
      "type": "integer",
      "minimum": 1
    },
    "imageHeight": {
      "type": "integer",
      "minimum": 1
    },
    "backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "endpoint": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
