{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-be-your-eyes/contracts/byes.ocr.v1.json",
  "title": "BYES OCR Payload v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "lines"
  ],
  "properties": {
    "schemaVersion": {
      "const": "byes.ocr.v1"
    },
    "runId": {
      "type": [
        "string",
        "null"
      ]
    },
    "frameSeq": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "endpoint": {
      "type": [
        "string",
        "null"
      ]
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "number"
            }
          }
        }
      }
    },
    "linesCount": {
      "type": "integer",
      "minimum": 0
    },
    "imageWidth": {
      "type": "integer",
      "minimum": 1
    },
    "imageHeight": {
      "type": "integer",
      "minimum": 1
    },
    "warningsCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
