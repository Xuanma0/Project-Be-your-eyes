{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "byes.assist_request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "deviceId", "targets"],
  "properties": {
    "schemaVersion": {
      "const": "byes.assist_request.v1"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": ["string", "null"],
      "enum": [
        "ocr",
        "det",
        "find",
        "risk",
        "depth",
        "seg",
        "slam",
        "target_start",
        "target_step",
        "target_stop",
        null
      ]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["ocr", "det", "risk", "depth", "seg", "slam"]
      }
    },
    "maxAgeMs": {
      "type": "integer",
      "minimum": 0
    },
    "cacheAgeMs": {
      "type": "integer",
      "minimum": 0
    },
    "prompt": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "sessionId": {
      "type": ["string", "null"]
    },
    "tracker": {
      "type": ["string", "null"],
      "enum": ["botsort", "bytetrack", null]
    },
    "roi": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "seg": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
