{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "frame.input.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "frameSeq",
    "captureTsMs",
    "recvTsMs",
    "meta"
  ],
  "properties": {
    "schemaVersion": {
      "const": "frame.input.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "frameSeq": {
      "type": "integer",
      "minimum": 1
    },
    "captureTsMs": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "recvTsMs": {
      "type": "integer",
      "minimum": 0
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deviceTimeBase": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "unix_ms",
            "monotonic_ms",
            null
          ]
        },
        "deviceId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": []
    }
  }
}
