{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-be-your-eyes/contracts/pov.ir.v1.json",
  "title": "POV IR v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "runId",
    "video",
    "decisionPoints",
    "events",
    "highlights",
    "tokens"
  ],
  "properties": {
    "schemaVersion": {
      "const": "pov.ir.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "video": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "fps": {
          "type": "number"
        },
        "durationSec": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "decisionPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "t0Ms",
          "t1Ms",
          "state",
          "action",
          "outcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "t0Ms": {
            "type": "integer",
            "minimum": 0
          },
          "t1Ms": {
            "type": "integer",
            "minimum": 0
          },
          "state": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
