# Be Your Eyes local config example (no real secrets)
# Copy values as needed before launching Gateway/services.

# Deployment profile
# local (default): developer-friendly, no extra hardening defaults
# hardened: enables safe defaults for internet-facing profile unless explicitly overridden
BYES_GATEWAY_PROFILE=local

# Gateway WS mode switches
GATEWAY_SEND_ENVELOPE=false
BYES_INFERENCE_EMIT_WS_V1=false

# Gateway optional auth / guardrails
# Empty => disabled (default local behavior unchanged)
BYES_GATEWAY_API_KEY=
BYES_GATEWAY_ALLOWED_HOSTS=
BYES_GATEWAY_ALLOWED_ORIGINS=

# Gateway dev/upload/local-path switches
# local defaults: 1/1/1, hardened defaults: 0/0/0
BYES_GATEWAY_DEV_ENDPOINTS_ENABLED=1
BYES_GATEWAY_RUNPACKAGE_UPLOAD_ENABLED=1
BYES_GATEWAY_ALLOW_LOCAL_RUNPACKAGE_PATH=1

# Gateway request size limits (bytes)
# local default: 0 (disabled); hardened defaults applied in main.py
BYES_GATEWAY_MAX_FRAME_BYTES=0
BYES_GATEWAY_MAX_RUNPACKAGE_ZIP_BYTES=0
BYES_GATEWAY_MAX_JSON_BYTES=0

# Gateway rate limit
# local default: disabled; hardened default: enabled
BYES_GATEWAY_RATE_LIMIT_ENABLED=0
BYES_GATEWAY_RATE_LIMIT_RPS=10
BYES_GATEWAY_RATE_LIMIT_BURST=20
BYES_GATEWAY_RATE_LIMIT_KEY_MODE=ip

# Mode-synced active perception profile (optional)
# Empty => keep current behavior (fully backward compatible)
BYES_MODE_PROFILE_JSON=
# Example:
# BYES_MODE_PROFILE_JSON={"default":{"risk":{"every_n_frames":1},"ocr":{"every_n_frames":3},"depth":{"every_n_frames":2}},"read":{"ocr":{"every_n_frames":1}},"walk":{"ocr":{"every_n_frames":4}}}
# Optional debug events (`mode.profile`) to WS/events stream
BYES_EMIT_MODE_PROFILE_DEBUG=0
# Optional debug events (`net.ping`) for ping endpoint
BYES_EMIT_NET_DEBUG=0
# Optional version diagnostics for /api/version
BYES_VERSION_OVERRIDE=
BYES_GIT_SHA=
# Assist cache for /api/assist
BYES_ASSIST_CACHE_TTL_MS=2000
BYES_ASSIST_CACHE_MAX_ENTRIES=16

# Quest capture tuning (Unity runtime reads these if provided)
# Android smoke defaults are async-on, low hz, low inflight
BYES_CAPTURE_USE_ASYNC_GPU_READBACK=1
BYES_CAPTURE_TARGET_HZ=1
BYES_CAPTURE_MAX_INFLIGHT=1

# Inference backend selectors
BYES_OCR_BACKEND=mock
BYES_RISK_BACKEND=mock
BYES_SEG_BACKEND=mock
BYES_DEPTH_BACKEND=mock
BYES_DET_BACKEND=mock
BYES_SLAM_BACKEND=mock

# Optional HTTP endpoints (used when backend=http)
BYES_SERVICE_OCR_ENDPOINT=http://127.0.0.1:19120/ocr
BYES_RISK_HTTP_URL=http://127.0.0.1:19120/risk
BYES_SEG_HTTP_URL=http://127.0.0.1:19120/seg
BYES_DEPTH_HTTP_URL=http://127.0.0.1:19120/depth
BYES_DET_HTTP_URL=http://127.0.0.1:19120/det
BYES_SLAM_HTTP_URL=http://127.0.0.1:19120/slam/pose

# Optional real provider settings (inference_service process)
# OCR
BYES_SERVICE_OCR_PROVIDER=mock
BYES_SERVICE_OCR_LANG=ch
BYES_SERVICE_OCR_USE_GPU=0
# DET
BYES_SERVICE_DET_PROVIDER=mock
BYES_SERVICE_DET_MODEL_PATH=
BYES_SERVICE_DET_MODEL=yolo11n.pt
BYES_SERVICE_DET_CONF=0.25
BYES_SERVICE_DET_IMGSZ=640
BYES_SERVICE_DET_OPENVOCAB=0
BYES_SERVICE_DET_PROMPT_DEFAULT=
BYES_SERVICE_DET_INCLUDE_MASK=1
# Depth
BYES_SERVICE_DEPTH_PROVIDER=none
BYES_SERVICE_DEPTH_ONNX_PATH=

# Planner
BYES_PLANNER_PROVIDER=reference
BYES_PLANNER_ENDPOINT=http://127.0.0.1:19211/plan

# LLM planner keys (placeholders)
BYES_PLANNER_LLM_API_KEY=YOUR_KEY_HERE
OPENAI_API_KEY=YOUR_KEY_HERE
