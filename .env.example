# Be Your Eyes local config example (no real secrets)
# Copy values as needed before launching Gateway/services.

# Gateway WS mode switches
GATEWAY_SEND_ENVELOPE=false
BYES_INFERENCE_EMIT_WS_V1=false

# Gateway optional auth / guardrails
# Empty => disabled (default local behavior unchanged)
BYES_GATEWAY_API_KEY=
BYES_GATEWAY_ALLOWED_HOSTS=
BYES_GATEWAY_ALLOWED_ORIGINS=

# Inference backend selectors
BYES_OCR_BACKEND=mock
BYES_RISK_BACKEND=mock
BYES_SEG_BACKEND=mock
BYES_DEPTH_BACKEND=mock
BYES_SLAM_BACKEND=mock

# Optional HTTP endpoints (used when backend=http)
BYES_SERVICE_OCR_ENDPOINT=http://127.0.0.1:19120/ocr
BYES_RISK_HTTP_URL=http://127.0.0.1:19120/risk
BYES_SEG_HTTP_URL=http://127.0.0.1:19120/seg
BYES_DEPTH_HTTP_URL=http://127.0.0.1:19120/depth
BYES_SLAM_HTTP_URL=http://127.0.0.1:19120/slam/pose

# Planner
BYES_PLANNER_PROVIDER=reference
BYES_PLANNER_ENDPOINT=http://127.0.0.1:19211/plan

# LLM planner keys (placeholders)
BYES_PLANNER_LLM_API_KEY=YOUR_KEY_HERE
OPENAI_API_KEY=YOUR_KEY_HERE
